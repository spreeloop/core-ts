{
  "name": "@spreeloop/geolocation",
  "version": "1.0.0",
  "description": "spreeloop core geolocation package",
  "author": "Spreeloop",
  "keywords": [
    "geolocation",
    "reverse-geocoding",
    "openstreetmap"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
